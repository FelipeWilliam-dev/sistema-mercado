<h2>{{title}}</h2>

{{#if cliente}}
    <form action="/clientes/editar/{{cliente.id_cliente}}" method="POST">
{{else}}
    <form action="/clientes/novo" method="POST">
{{/if}}

    <div>
        <label for="nome_cliente">Nome do Cliente:</label>
        <input type="text" id="nome_cliente" name="nome_cliente" value="{{cliente.nome_cliente}}" required>
    </div>
    <br>
    <div>
        <label for="cpf">CPF:</label>
        <input type="text" id="cpf" name="cpf" value="{{cliente.cpf}}">
    </div>
    <br>
    <div>
        <label for="email_cliente">Email:</label>
        <input type="email" id="email_cliente" name="email_cliente" value="{{cliente.email_cliente}}">
    </div>
    <br>
    <div>
        <label for="telefone_cliente">Telefone:</label>
        <input type="text" id="telefone_cliente" name="telefone_cliente" value="{{cliente.telefone_cliente}}">
    </div>
    <br>
    <button type="submit">Salvar</button>
    <a href="/clientes">Cancelar</a>
</form>