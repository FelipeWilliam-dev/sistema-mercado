<h2>{{title}}</h2>

{{#if isFirstUser}}
    <p style="background-color: #eef; padding: 10px; border: 1px solid #ccd;">
        <b>Setup Inicial:</b> O primeiro usuário será registrado automaticamente como <b>Administrador</b>.
    </p>
{{/if}}

<form action="/usuarios/novo" method="POST">
    <div>
        <label for="nome_usuario">Nome Completo:</label>
        <input type="text" id="nome_usuario" name="nome_usuario" required>
    </div>
    <br>
    <div>
        <label for="login">Login:</label>
        <input type="text" id="login" name="login" required>
    </div>
    <br>
    <div>
        <label for="senha">Senha:</label>
        <input type="password" id="senha" name="senha" required>
    </div>
    <br>

    {{#unless isFirstUser}} <div>
        <label for="tipo_acesso">Tipo de Acesso:</label>
        <select name="tipo_acesso" id="tipo_acesso" required>
            <option value="vendedor">Vendedor</option>
            <option value="admin">Administrador</option>
        </select>
    </div>
    <br>
    {{/unless}}

    <button type="submit">Salvar</button>
    <a href="/usuarios">Cancelar</a>
</form>